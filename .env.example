# Meta Ads Copilot — Environment Variables
#
# This repo uses a local adapter around Meta's official Ads CLI.
# Official docs: https://developers.facebook.com/documentation/ads-commerce/ads-ai-connectors/ads-cli/ads-cli-overview
# Install: pip install meta-ads (Python 3.12+; uv supported)

# Official Ads CLI auth/config (do not commit real secrets)
# Ads CLI expects ACCESS_TOKEN + AD_ACCOUNT_ID. META_* aliases are accepted by
# this kit for backwards compatibility, but official commands use these names.
ACCESS_TOKEN=
AD_ACCOUNT_ID=act_123456789
BUSINESS_ID=

# Legacy/kit aliases (optional)
META_SYSTEM_USER_ACCESS_TOKEN=
META_AD_ACCOUNT=
META_BUSINESS_ID=
META_APP_ID=
META_APP_SECRET=

# Kit behavior
META_KIT_MODE=mock
META_KIT_OUTPUT=json
META_KIT_DEFAULT_PRESET=last_7d
META_KIT_REQUIRE_APPROVAL=true
META_KIT_FORCE_PAUSED=true
META_KIT_DRY_RUN_DIR=local/dry-runs

# Optional local env file override for account/client separation
# META_KIT_ENV_FILE=.env.client.local
